        "\n",
        "#Train and evaluate ReLU model\n",
        "print(\"Training relu model....\")\n",
        "relu_accuracy, relu_preds = train_and_evaluate(relu_model, X_train, X_test, y_test, y_train)\n",
        "\n",
        "print(f\"Accuracy with relu activation: {relu_accuracy}\")\n",
        "\n",
        "#visualize decision boundaries\n",
        "def plot_decision_boundary(model, X, y, title):\n",
        "  x_min, x_max = X[:, 0].min() -1, X[:, 0].max() + 1\n",
        "  y_min, y_max = X[:, 1].min() -1, X[:, 1].max() + 1 # Fixed error X[:,0] to X[:,1]\n",
